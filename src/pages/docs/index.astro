---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { getGroupedDocs } from '../../utils/docs';

const groupedByCategory = await getGroupedDocs();

// Sort categories in order
const categoryOrder = [
  'GETTING STARTED',
  'CORE CONCEPTS',
  'AGENTS',
  'SKILLS & TOOLS',
  'HARNESS',
  'PLUGINS',
  'STUDIO',
  'ADVANCED',
  'API REFERENCE',
];

// Debug: log what we found
console.log('Found docs:', Object.keys(groupedByCategory), Object.values(groupedByCategory).reduce((sum, arr) => sum + arr.length, 0));
---

<DocsLayout title="Documentation - Zod" showSidebar={true} currentSlug="" groupedDocs={groupedByCategory}>
  <div class="p-4 xl:p-8 2xl:pr-4">
    <div class="mx-auto max-w-4xl">
      <div class="mb-16">
        <h1 class="text-5xl font-semibold tracking-tight text-gray-950 sm:text-6xl dark:text-white">
          Documentation
        </h1>
        <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
          Everything you need to know about Zod, the open-source AI agent framework.
        </p>
      </div>

      <div class="flex flex-col gap-16">
        {categoryOrder.filter(cat => groupedByCategory[cat]).map((category) => (
          <div>
            <h2 class="text-sm/6 font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              {category}
            </h2>
            <ul class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
              {groupedByCategory[category].map((doc) => (
                <li>
                  <a 
                    href={`/docs/${doc.slug}`}
                    class="group relative flex flex-col gap-2 rounded-xl border border-gray-950/5 bg-white p-6 transition-colors hover:border-gray-950/10 hover:bg-gray-950/2.5 dark:border-white/10 dark:bg-white/2.5 dark:hover:border-white/20 dark:hover:bg-white/5"
                  >
                    <h3 class="text-base font-semibold text-gray-950 group-hover:text-cyan-700 dark:text-white dark:group-hover:text-cyan-300">
                      {doc.data.title}
                    </h3>
                    {doc.data.description && (
                      <p class="text-sm text-gray-600 dark:text-gray-400">
                        {doc.data.description}
                      </p>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</DocsLayout>
