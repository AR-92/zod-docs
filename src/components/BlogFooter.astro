---
// BlogFooter component - Footer with newsletter signup for blog pages
import { Mail } from 'lucide-astro';
---

<div class="mt-16">
  {/* Newsletter Section */}
  <div class="px-4 py-4 sm:py-2 lg:px-2 relative before:absolute before:top-0 before:h-px before:w-[200vw] before:bg-gray-950/5 dark:before:bg-white/10 before:-left-[100vw] after:absolute after:bottom-0 after:h-px after:w-[200vw] after:bg-gray-950/5 dark:after:bg-white/10 after:-left-[100vw]">
    <section>
      <h2 class="text-3xl font-medium tracking-tight text-slate-900 dark:text-white">Get all of our updates directly to your&nbsp;inbox.<br>Sign up for our newsletter.</h2>
      <div class="mt-10 max-w-md">
        <form class="flex flex-nowrap gap-4" action="#" method="post">
          <div class="max-w-82 flex-1">
            <div class="group relative">
              <div class="pointer-events-none absolute left-4 flex h-full items-center">
                <Mail class="size-4 text-gray-950/50 group-focus-within:text-gray-950 dark:text-white/50 dark:group-focus-within:text-white" />
              </div>
              <input type="email" required="" autocomplete="email" aria-label="Email address" class="block w-full appearance-none rounded-4xl bg-white py-2 pr-3 pl-10 text-sm/6 text-gray-950 outline -outline-offset-1 outline-gray-950/8 placeholder:text-sm/6 placeholder:text-gray-950/50 focus:outline-gray-950 dark:bg-white/10 dark:text-white/50 dark:outline-white/15 dark:placeholder:text-white/50 dark:focus:outline-white" placeholder="Subscribe via email" name="email_address">
            </div>
          </div>
          <div>
            <button type="submit" class="rounded-4xl bg-black px-4 py-2 text-sm/6 font-semibold text-white hover:bg-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600">Subscribe</button>
          </div>
        </form>
      </div>
    </section>
  </div>

  {/* Footer */}
  <div class="mt-46 relative before:absolute before:top-0 before:h-px before:w-[200vw] before:bg-gray-950/5 dark:before:bg-white/10 before:-left-[100vw] after:absolute after:bottom-0 after:h-px after:w-[200vw] after:bg-gray-950/5 dark:after:bg-white/10 after:-left-[100vw]">
    <footer class="bg-white text-sm/loose text-gray-950 dark:bg-gray-950 dark:text-white">
      <div class="flex gap-4 p-4 md:hidden max-w-2xl lg:max-w-5xl">
        <div class="flex flex-1 flex-col gap-10">
          <div>
            <h3 class="font-semibold">Zod</h3>
            <ul class="mt-4 grid gap-4">
              <li><a class="hover:underline" href="/docs">Documentation</a></li>
              <li><a class="hover:underline" href="/docs">API Reference</a></li>
              <li><a class="hover:underline" href="/blog">Blog</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold">Legal</h3>
            <ul class="mt-4 grid gap-4">
              <li><a class="hover:underline" href="/legal/privacy">Privacy Policy</a></li>
              <li><a class="hover:underline" href="/legal/terms">Terms of Service</a></li>
              <li><a class="hover:underline" href="/legal/license">License</a></li>
              <li><a class="hover:underline" href="/legal/trademark">Trademark</a></li>
            </ul>
          </div>
        </div>
        <div class="flex flex-1 flex-col gap-10">
          <div>
            <h3 class="font-semibold">Resources</h3>
            <ul class="mt-4 grid gap-4">
              <li><a class="hover:underline" href="#">Tutorials</a></li>
              <li><a class="hover:underline" href="#">Showcase</a></li>
              <li><a class="hover:underline" href="#">Examples</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="mx-auto hidden w-full grid-cols-3 justify-between gap-y-0 md:grid md:grid-cols-3 md:gap-6 md:gap-x-4 lg:gap-8 max-w-2xl lg:max-w-5xl">
        <div class="border-x border-b border-gray-950/5 py-10 pl-2 not-md:border-0 md:border-b-0 dark:border-white/10">
          <h3 class="font-semibold">Zod</h3>
          <ul class="mt-4 grid gap-4">
            <li><a class="hover:underline" href="/docs">Documentation</a></li>
            <li><a class="hover:underline" href="/docs">API Reference</a></li>
            <li><a class="hover:underline" href="/blog">Blog</a></li>
          </ul>
        </div>
        <div class="border-x border-b border-gray-950/5 py-10 pl-2 not-md:border-0 md:border-b-0 dark:border-white/10">
          <h3 class="font-semibold">Resources</h3>
          <ul class="mt-4 grid gap-4">
            <li><a class="hover:underline" href="#">Tutorials</a></li>
            <li><a class="hover:underline" href="#">Showcase</a></li>
            <li><a class="hover:underline" href="#">Examples</a></li>
          </ul>
        </div>
        <div class="border-x border-gray-950/5 py-10 pl-2 not-md:border-0 dark:border-white/10">
          <h3 class="font-semibold">Legal</h3>
          <ul class="mt-4 grid gap-4">
            <li><a class="hover:underline" href="/legal/privacy">Privacy Policy</a></li>
            <li><a class="hover:underline" href="/legal/terms">Terms of Service</a></li>
            <li><a class="hover:underline" href="/legal/license">License</a></li>
            <li><a class="hover:underline" href="/legal/trademark">Trademark</a></li>
          </ul>
        </div>
      </div>
    </footer>
  </div>
</div>
