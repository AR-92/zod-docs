---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
}

const { src, alt, width = 800, height = 400, class: className } = Astro.props;
---

<div class="not-prose relative overflow-hidden rounded-xl">
  <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-gray-950/10 ring-inset dark:ring-white/10"></div>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading="lazy"
    decoding="async"
    class:list={["w-full h-auto object-cover", className]}
  />
</div>